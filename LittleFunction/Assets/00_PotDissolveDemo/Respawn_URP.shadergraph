    "m_ObjectId": "5a25fe67164c43989292f3c839b886e0",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ComputeEmission (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 426.0,
            "y": 493.0,
            "width": 257.0,
            "height": 261.99993896484377
        }
    },
    "m_Slots": [
        {
            "m_Id": "26c912617a6c4ebf9314d1968ae1cb10"
        },
        {
            "m_Id": "2eec138cde014392863aefad857c22e8"
        },
        {
            "m_Id": "9bb7b71007344ad0b530987571db45f7"
        },
        {
            "m_Id": "e1ed2db34e484d01b89ecea50f279677"
        },
        {
            "m_Id": "faf2de06a60540de871c9fb98ee8d09c"
        },
        {
            "m_Id": "c35c2cbb5f5c41559008757f1735f801"
        },
        {
            "m_Id": "256b01fa031345048f7512de430c0432"
        },
        {
            "m_Id": "c1f05af61e334a618281e696256c50be"
        },
        {
            "m_Id": "8f2affe109104e648cba6b832ece2ad3"
        },
        {
            "m_Id": "36c1541024c24129b37dfcf1fb652989"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ComputeEmission",
    "m_FunctionSource": "",
    "m_FunctionBody": "float2 uv = uv_noise;\nuv.y += cutoffDEV;\nhalf3 noise = tex2D (noiseTex, uv);\r\nnoise.r = lerp(0, 1, noise.r);\ncutoffDEV = 1 - cutoffDEV;\nhalf edge = smoothstep(cutoffDEV + edgeSize, cutoffDEV, clamp(noise.r, edgeSize, 1));\nfloat4 c = tex2D (mainTex, uv_mainTex);\nfloat3 emissiveCol = c.a * emission;\nEmission = emissiveCol + edgeColor1 * edge;\t\nCutoff =  noise.r - _cutoff;"
}

